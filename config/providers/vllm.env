# vLLM Configuration — Production Inference Server
# https://github.com/vllm-project/vllm
#
# Install:
#   pip install vllm                    # GPU (CUDA)
#   pip install vllm --torch-backend cpu # CPU
#
# Start serving:
#   vllm serve Qwen/Qwen3-0.6B --host 0.0.0.0 --port 8000
#   vllm serve meta-llama/Llama-3.1-8B-Instruct --host 0.0.0.0 --port 8000 --dtype auto
#   vllm serve Qwen/Qwen3-8B --host 0.0.0.0 --port 8000 --api-key YOUR_KEY
#
# Store base URL in vault:
#   python manage_credentials.py store vllm_base_url http://YOUR_HOST:8000
#   python manage_credentials.py store vllm_api_key YOUR_KEY  # optional
#
# OpenAI-compatible API endpoints:
#   /v1/chat/completions, /v1/completions, /v1/models, /health
#
# Optional overrides (non-secret, safe in this file):
# VLLM_BASE_URL=http://localhost:8000
