# WordPress publishing — vault-backed, decrypt-on-demand.
#
# Secrets DO NOT live here. They live in the BANKON vault under the isolated
# context="wordpress.agent.keys" namespace and are decrypted on-demand per
# /publish by the wordpress-agent service. See docs/WORDPRESS_PUBLISHING.md.
#
# One-time provisioning (mints the wordpress.agent wallet + seeds WP creds):
#   sudo -u mindx /home/mindx/mindX/.mindx_env/bin/python \
#       /home/mindx/mindX/scripts/vault/provision_wordpress_agent.py \
#       --wp-base-url https://rage.pythai.net --wp-user codephreak \
#       --publisher-addresses 0xAaa...,0xBbb...
#
# Allowlist of external wallets permitted to request a publish (env-mapped):
#   python manage_credentials.py store wordpress_publisher_addresses "0xAaa,0xBbb"
# → loaded into WORDPRESS_PUBLISHER_ADDRESSES at backend startup by
#   mindx_backend_service/bankon_vault/credential_provider.py
#
# Vault namespace contents (isolated; NOT env-mapped; never loaded into os.environ):
#   wordpress.agent:pk                -- wallet private key (hex)
#   wordpress.agent:address           -- public identity (also in production_registry.json)
#   wordpress.agent:wp_app_password   -- WP Application Password (API key)
#   wordpress.agent:wp_base_url       -- https://rage.pythai.net
#   wordpress.agent:wp_user           -- WP username
#
# Operational overrides — NON-SECRET ONLY (safe to put in /etc/wordpress-agent/wordpress-agent.env):
# WP_SERVER_HOST=127.0.0.1
# WP_SERVER_PORT=8765
# WP_TIMEOUT=30
# WP_RETRY_COUNT=3
# WP_RETRY_BACKOFF=0.5
# MINDX_WORDPRESS_AGENT_URL=http://127.0.0.1:8765
#
# Local dev fallback (only when the vault namespace is empty — never set WP_APP_PASSWORD in production):
# WP_BASE_URL=https://rage.example.test
# WP_USER=codephreak
# WP_APP_PASSWORD=
