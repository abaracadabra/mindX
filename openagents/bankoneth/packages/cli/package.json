{
  "name": "@bankoneth/cli",
  "version": "0.1.0",
  "description": "bankoneth CLI — claim, purchase, host, quote. Wraps @bankoneth/core in a commander-based command surface.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "bankoneth": "./dist/index.js"
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "@bankoneth/core": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^2.1.0",
    "@types/node": "^20.16.0"
  },
  "keywords": ["bankoneth", "ens", "cli", "bankon.eth"]
}
