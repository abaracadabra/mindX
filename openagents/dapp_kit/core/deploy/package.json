  "description": "Foundry + AlgoKit deployment drivers for openagents/ dApp kit. Pre-flight checks, deterministic deployment records, two-step mainnet confirmation.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
