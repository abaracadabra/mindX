# Compiler files
cache/
out/

# Ignores development broadcast logs
!/broadcast
/broadcast/*/31337/
/broadcast/**/dry-run/

# Docs
docs/

# Dotenv files — every variant; deploy keys must never land in git.
# Sample templates are explicitly tracked.
.env
.env.*
!.env.*.sample

# Deployments dir tracks committed receipts but not local broadcast metadata.
deployments/dry-run/
deployments/**/run-*.json
