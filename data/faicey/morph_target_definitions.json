  "blending_rules": {
    "mouth_visemes": {
      "exclusive": true,
      "description": "Only one viseme should be active at a time (with blending)",
      "blend_method": "weighted_average"
    },
    "eyes": {
      "exclusive": false,
      "description": "Eye states can combine (e.g., look-left + blink)",
      "blend_method": "additive"
    },
    "eyebrows": {
      "exclusive": true,
      "description": "One primary eyebrow state at a time",
      "blend_method": "weighted_average"
    },
    "ears": {
      "exclusive": true,
      "description": "One ear state at a time",
      "blend_method": "weighted_average"
    }
  },
  
  "animation_timing": {
