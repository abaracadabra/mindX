    "github_agent_tool": {
      "enabled": true,
      "class_name": "GitHubAgentTool",
      "module_path": "tools.github_agent_tool",
      "description": "GitHub-focused agent for coordinating mindX branch backups, restores, milestone monitoring, and pre-upgrade backups. Ensures mindX always has a working fallback state in GitHub.",
      "priority": 10,
      "category": "version_control",
      "access_control": {
        "allowed_agents": ["mastermind_prime", "coordinator_agent", "strategic_evolution_agent"]
      },
      "commands": [
        {
          "name": "create_backup",
          "description": "Create a backup branch before major changes",
          "parameters": [
            {"name": "backup_type", "type": "str", "required": false},
            {"name": "reason", "type": "str", "required": true},
            {"name": "branch_name", "type": "str", "required": false}
          ]
        },
        {
          "name": "restore_from_backup",
          "description": "Restore mindX from a backup branch",
          "parameters": [
            {"name": "branch_name", "type": "str", "required": true},
            {"name": "target_branch", "type": "str", "required": false}
          ]
        },
        {
          "name": "check_milestones",
          "description": "Check for milestone updates and apply policy",
          "parameters": []
        },
        {
          "name": "detect_architectural_changes",
          "description": "Detect architectural changes and ensure backup exists",
          "parameters": []
        },
        {
          "name": "pre_upgrade_backup",
          "description": "Create backup before major architectural upgrade",
          "parameters": [
            {"name": "upgrade_description", "type": "str", "required": true}
          ]
        },
        {
          "name": "list_backups",
          "description": "List all available backup branches",
          "parameters": []
        },
        {
          "name": "get_backup_status",
          "description": "Get current status of backup system",
          "parameters": []
        }
      ]
    },
    "prompt_tool": {
      "enabled": true,
      "class_name": "PromptTool",
      "module_path": "tools.prompt_tool",
      "description": "Manages, stores, and executes prompts as first-class infrastructure. Prompts are versioned, searchable, and can be ingested from external sources like AgenticPlace.",
      "priority": 7,
      "category": "cognition",
      "commands": [
        {
          "name": "create",
          "description": "Create a new prompt",
          "parameters": [
            {"name": "name", "type": "str", "required": true},
            {"name": "content", "type": "str", "required": true},
            {"name": "description", "type": "str", "required": false},
            {"name": "prompt_type", "type": "str", "required": false},
            {"name": "category", "type": "str", "required": false},
            {"name": "tags", "type": "list", "required": false}
          ]
        },
        {
          "name": "get",
          "description": "Retrieve a prompt by ID",
          "parameters": [
            {"name": "prompt_id", "type": "str", "required": true}
          ]
        },
        {
          "name": "execute",
          "description": "Execute a prompt with variable substitution",
          "parameters": [
            {"name": "prompt_id", "type": "str", "required": true},
            {"name": "variables", "type": "dict", "required": false}
          ]
        },
        {
          "name": "search",
          "description": "Search prompts by content or metadata",
          "parameters": [
            {"name": "query", "type": "str", "required": true},
            {"name": "search_content", "type": "bool", "required": false}
          ]
        },
        {
          "name": "ingest",
          "description": "Ingest a prompt from external source (e.g., AgenticPlace)",
          "parameters": [
            {"name": "name", "type": "str", "required": true},
            {"name": "content", "type": "str", "required": true},
            {"name": "source", "type": "str", "required": false}
          ]
        }
      ]
