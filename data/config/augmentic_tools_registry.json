          "parameters": [
            {"name": "name", "type": "str", "required": true},
            {"name": "content", "type": "str", "required": true},
            {"name": "description", "type": "str", "required": false},
            {"name": "prompt_type", "type": "str", "required": false},
            {"name": "category", "type": "str", "required": false},
            {"name": "tags", "type": "list", "required": false}
          ]
        },
        {
          "name": "get",
          "description": "Retrieve a prompt by ID",
          "parameters": [
            {"name": "prompt_id", "type": "str", "required": true}
          ]
        },
        {
          "name": "execute",
          "description": "Execute a prompt with variable substitution",
          "parameters": [
            {"name": "prompt_id", "type": "str", "required": true},
            {"name": "variables", "type": "dict", "required": false}
          ]
        },
        {
          "name": "search",
          "description": "Search prompts by content or metadata",
          "parameters": [
            {"name": "query", "type": "str", "required": true},
            {"name": "search_content", "type": "bool", "required": false}
          ]
        },
        {
          "name": "ingest",
          "description": "Ingest a prompt from external source (e.g., AgenticPlace)",
          "parameters": [
            {"name": "name", "type": "str", "required": true},
