
/* --- corporate display and global dominance doctrine --- */
:root {
    --primary-color: #00bcd4;
    --primary-hover: #ffffff;
    --dark-base: #010408;
    --light-text: #f0faff;
    --medium-text: #90a4ae;
    --subtle-text: #455a64;
    --dark-text: #000;
    --section-bg: rgba(2, 8, 15, 0.98);
    --header-bg: rgba(1, 4, 8, 0.98);
    --accent-shadow-color: rgba(0, 188, 212, 0.5);
    --accent-shadow-hover: rgba(0, 188, 212, 0.8);
    --font-primary: 'Inter', sans-serif;
    --font-mono: 'Fira Code', monospace;
    --terminal-green: #00ff41;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
    font-family: var(--font-primary);
    background-color: var(--dark-base);
    background-image: 
        radial-gradient(circle at 50% 50%, rgba(0, 188, 212, 0.18), transparent),
        linear-gradient(rgba(0, 0, 0, 0.96), rgba(0, 0, 0, 0.98)),
        url('input_file_2.png');
    background-size: cover;
    background-attachment: fixed;
    color: var(--light-text);
    overflow: hidden;
}

/* CRT Scanline Overlay */
.app-container::after {
    content: " ";
    position: fixed;
    top: 0; left: 0; bottom: 0; right: 0;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), 
                linear-gradient(90deg, rgba(255, 0, 0, 0.05), rgba(0, 255, 0, 0.03), rgba(0, 0, 255, 0.05));
    z-index: 10000000;
    background-size: 100% 3px, 5px 100%;
    pointer-events: none;
    opacity: 0.5;
}

.workspace-canvas { width: 100vw; height: 100vh; position: relative; padding-top: 80px; overflow: hidden; }

/* Console Substrate Layout */
.console-layout.flipped-central {
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    overflow: hidden;
}

/* Supreme Directive Shell - Absolute Focal Priority */
.central-panel {
    background: #000 !important;
    border: 3px solid var(--terminal-green) !important;
    padding: 25px !important;
    box-shadow: 0 0 60px rgba(0, 255, 65, 0.25) !important;
    position: relative;
    z-index: 100;
    flex-shrink: 0;
    border-radius: 6px 6px 0 0;
}
.central-panel textarea {
    background: rgba(0, 25, 0, 0.5) !important;
    border: 1px solid rgba(0, 255, 65, 0.4) !important;
    color: #fff !important;
    font-size: 1.8rem !important;
    height: 150px !important;
    font-family: var(--font-mono);
    line-height: 1.3;
    outline: none !important;
    width: 100%;
    resize: none;
    padding: 20px;
    caret-color: var(--terminal-green);
    border-radius: 4px;
}

.response-field-wrapper {
    flex-grow: 1;
    display: flex;
    overflow: hidden;
    position: relative;
    background: rgba(0,0,0,0.8);
    border-bottom: 2px solid rgba(0, 188, 212, 0.2);
}

/* Tactical Navigation Arrow Sidebar */
.nav-arrow-sidebar {
    width: 64px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 32px;
    border-right: 1px solid rgba(0, 188, 212, 0.2);
    background: rgba(0,0,0,0.7);
    z-index: 10;
}
.nav-arrow {
    background: transparent;
    border: 1px solid var(--primary-color);
    color: var(--primary-color);
    font-size: 1.5rem;
    padding: 14px;
    cursor: pointer;
    transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
}
.nav-arrow:hover { 
    background: var(--primary-color); 
    color: #000; 
    box-shadow: 0 0 25px var(--primary-color); 
    transform: scale(1.1); 
}
.nav-arrow:active { transform: scale(0.9); opacity: 0.7; }

/* Response Field interaction */
.response-field {
    flex-grow: 1; 
    padding: 40px; 
    overflow-y: auto; 
    display: flex; 
    flex-direction: column; 
    gap: 20px; 
    font-family: var(--font-mono);
    scroll-behavior: smooth;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Scrollbar Style */
.response-field::-webkit-scrollbar { width: 8px; }
.response-field::-webkit-scrollbar-track { background: rgba(0,0,0,0.6); }
.response-field::-webkit-scrollbar-thumb { background: var(--primary-color); border-radius: 4px; box-shadow: 0 0 10px var(--primary-color); }

/* Plane Scrubber Footer */
.substrate-footer-scrubber {
    height: 64px;
    background: #000;
    border-top: 2px solid rgba(0, 188, 212, 0.3);
    padding: 0 40px;
    display: flex;
    align-items: center;
    gap: 30px;
    border-radius: 0 0 6px 6px;
}
.scrubber-label { font-size: 0.75rem; color: var(--primary-color); font-weight: 900; letter-spacing: 3px; }
.substrate-slider {
    flex-grow: 1;
    -webkit-appearance: none;
    height: 4px;
    background: rgba(0, 188, 212, 0.2);
    outline: none;
    border-radius: 2px;
}
.substrate-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 100px;
    height: 16px;
    background: var(--primary-color);
    cursor: pointer;
    border-radius: 2px;
    box-shadow: 0 0 25px var(--primary-color);
    border: none;
}

/* Message Emergence Physics */
.history-line {
    font-size: 1.05rem; line-height: 1.8; padding: 20px 30px; border-radius: 6px;
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    animation: messageEmerge 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
@keyframes messageEmerge {
    from { opacity: 0; transform: translateY(-50px) scale(0.95); filter: blur(20px); }
    to { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
}

.history-line.status-transmitting {
    color: #fff !important;
    background: rgba(0, 188, 212, 0.4) !important;
    border-left: 8px solid var(--primary-color);
    box-shadow: 0 0 40px rgba(0, 188, 212, 0.35);
    text-shadow: 0 0 12px #fff;
    font-weight: 900;
}
.history-line.status-accepted {
    color: var(--medium-text);
    background: rgba(255, 255, 255, 0.05);
    border-left: 8px solid rgba(255, 255, 255, 0.1);
}
.history-line.agent {
    border-left-color: #FF33FF;
    background: rgba(255, 51, 255, 0.1);
    color: #FFEAFF;
}

/* Window HUD Styling */
.hud-window {
    background: var(--section-bg);
    border: 2px solid rgba(0, 188, 212, 0.4);
    box-shadow: 0 40px 150px rgba(0,0,0,1);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
}
.window-handle { 
    height: 48px; 
    background: #000; 
    border-bottom: 2px solid rgba(0, 188, 212, 0.3); 
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 20px;
    cursor: grab;
}
.window-handle:active { cursor: grabbing; }

.window-content-inner {
    flex-grow: 1;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
}

/* resizer handle */
.window-corner-resizer {
    position: absolute; bottom: 0; right: 0; width: 30px; height: 30px;
    cursor: nwse-resize; background: linear-gradient(135deg, transparent 60%, rgba(0, 188, 212, 0.6) 60%);
    z-index: 101;
}

/* Transmit Button Dominance */
.transmit-btn-dominance {
    background: var(--primary-color); color: #000; font-weight: 900;
    padding: 18px 60px; border: none; border-radius: 4px; cursor: pointer; font-size: 1.2rem;
    box-shadow: 0 0 50px rgba(0, 188, 212, 0.45); letter-spacing: 5px; transition: 0.3s all ease;
    text-transform: uppercase;
}
.transmit-btn-dominance:hover:not(:disabled) { transform: translateY(-4px) scale(1.04); background: #fff; box-shadow: 0 20px 60px rgba(0, 188, 212, 0.8); }
.transmit-btn-dominance:active { transform: translateY(0) scale(0.98); }
.transmit-btn-dominance:disabled { opacity: 0.4; filter: grayscale(1); pointer-events: none; }

/* Notifications UI */
.global-notification {
    position: fixed; top: 130px; left: 50%; transform: translateX(-50%);
    background: var(--primary-color); color: #000; padding: 14px 50px;
    font-weight: 900; font-size: 0.85rem; z-index: 10000000; letter-spacing: 4px;
    box-shadow: 0 0 50px var(--primary-color);
    border-radius: 4px;
    text-transform: uppercase;
    animation: notifyPulse 2s infinite ease-in-out;
}
@keyframes notifyPulse {
    0% { box-shadow: 0 0 30px var(--primary-color); }
    50% { box-shadow: 0 0 70px var(--primary-color); }
    100% { box-shadow: 0 0 30px var(--primary-color); }
}
